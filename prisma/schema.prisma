// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A writer identity / pen name. Multiple profiles are supported; each profile
// owns its own set of books. The active profile is chosen client-side.
model Profile {
  id        String   @id @default(cuid())
  penName   String
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books Book[]
}

// A creative project: novel, komik, film plot, game, etc.
model Book {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("Novel") // Novel | Komik | Film | Game | Lainnya
  genre       String?
  accent      String   @default("amber") // cover accent color key
  status      String   @default("draft") // draft | writing | editing | done
  profileId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile      Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  plotNodes    PlotNode[]
  worldEntries WorldEntry[]
  wikiEntries  WikiEntry[]
}

// Story structure: acts, chapters, scenes, beats, notes.
model PlotNode {
  id        String   @id @default(cuid())
  bookId    String
  title     String
  summary   String?
  content   String?
  kind      String   @default("chapter") // act | chapter | scene | beat | note
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

// World building entries: locations, cultures, history, magic systems, etc.
model WorldEntry {
  id        String   @id @default(cuid())
  bookId    String
  title     String
  category  String   @default("other")
  content   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

// Wiki entries: characters, items, factions, events, concepts, etc.
model WikiEntry {
  id        String   @id @default(cuid())
  bookId    String
  title     String
  category  String   @default("character")
  content   String?
  tags      String? // comma separated
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}
